// Prisma 7 — схема каталога аренды авто.
// Генератор: prisma-client (Prisma 7), клиент генерируется в src/generated/prisma
// и НЕ коммитится. Фаза 4: добавлена модель Booking (заявки на аренду).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  // Prisma 7: URL-адреса задаются в prisma.config.ts, а не здесь.
  // Рантайм-клиент подключается через driver adapter (Neon), см. src/lib/db.ts.
  provider = "postgresql"
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
}

enum Drivetrain {
  FWD
  RWD
  AWD
}

model City {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cars     Car[]
  bookings Booking[]
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cars Car[]

  // priceFrom намеренно не храним — вычисляется из минимальных цен авто категории.
}

model Car {
  id              String       @id @default(cuid())
  slug            String       @unique
  brand           String
  model           String
  fullName        String
  bodyType        String
  year            Int
  transmission    Transmission
  fuel            FuelType
  drivetrain      Drivetrain
  seats           Int
  doors           Int
  luggage         Int
  engine          String
  airConditioning Boolean      @default(true)
  dailyPrice      Int // USD, равен минимальному тарифу (30+ суток)
  deposit         Int // USD, возвратный залог
  featured        Boolean      @default(false)
  available       Boolean      @default(true)
  imageAlt        String
  description     String
  features        String[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  cityId     String
  city       City     @relation(fields: [cityId], references: [id])

  photos     CarPhoto[]
  priceTiers PriceTier[]
  bookings   Booking[]

  @@index([categoryId])
  @@index([cityId])
  @@index([available])
  @@index([featured])
}

model CarPhoto {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  url       String
  alt       String
  isCover   Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([carId])
}

model PriceTier {
  id         String   @id @default(cuid())
  carId      String
  car        Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  minDays    Int
  maxDays    Int? // null = диапазон без верхней границы (30+)
  pricePerDay Int
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([carId, minDays])
  @@index([carId])
}

// Фаза 4 — заявка на аренду.
// Финансовые поля (rentalDays/dailyRate/rentalTotal/depositAmount) — snapshot:
// рассчитываются сервером из БД и не доверяются клиенту. Залог хранится отдельно
// и НЕ входит в rentalTotal. carName/carSlug — snapshot на случай изменения авто.

enum BookingStatus {
  NEW
  CONTACTED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum BookingSource {
  WEBSITE
  PHONE
  ADMIN
}

model Booking {
  id             String @id @default(cuid())
  publicId       String @unique @default(cuid()) // публичный безопасный идентификатор
  idempotencyKey String @unique // защита от дублей при повторном submit

  carId String
  car   Car    @relation(fields: [carId], references: [id], onDelete: Restrict)

  cityId String
  city   City   @relation(fields: [cityId], references: [id], onDelete: Restrict)

  carName String // snapshot названия авто
  carSlug String // snapshot slug авто

  customerName  String
  customerPhone String // нормализованный
  customerEmail String?

  pickupDate DateTime // UTC
  returnDate DateTime // UTC

  rentalDays    Int // snapshot, считает сервер
  dailyRate     Int // snapshot тарифа (USD/сутки)
  rentalTotal   Int // snapshot стоимости аренды (USD)
  depositAmount Int // snapshot залога (USD, отдельно от аренды)

  comment String?

  consentAcceptedAt DateTime // ставит сервер (new Date())
  privacyVersion    String // ставит сервер (константа)

  status BookingStatus @default(NEW)
  source BookingSource @default(WEBSITE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carId])
  @@index([cityId])
  @@index([status])
  @@index([createdAt])
  @@index([customerPhone])
}

# Пример переменных окружения (БЕЗ реальных значений).
# Реальные значения хранятся только в .env.local (development) и
# .env.production.local (production) — эти файлы игнорируются Git.

# PostgreSQL (Neon). Pooled — для рантайма, unpooled — для миграций.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Telegram-уведомления о новых заявках (Фаза 6).
# Если обе пустые — Telegram выключен. Задать нужно обе.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
